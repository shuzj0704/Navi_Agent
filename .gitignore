# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/

# Data (simulation outputs, too large for git).
# Use file-by-file matching (data/*) instead of dir match (data/) so we can
# re-include navigation route waypoint files below — gitignore can't recover
# files from a fully-excluded parent directory.
data/*
!data/urbanverse/
data/urbanverse/*
!data/urbanverse/trajectory/
data/urbanverse/trajectory/*
!data/urbanverse/trajectory/scene_*/
data/urbanverse/trajectory/scene_*/*
# Track only the human-authored route waypoints (.txt). The dense JSON / PNG
# generated by interpolate_trajectory.py stay ignored.
!data/urbanverse/trajectory/scene_*/*.txt

# add docs
# docs/

# RL policy weights and robot URDF/mesh assets (download from external repos)
# Policy: https://github.com/fan-ziqi/rl_sar/tree/main/policy
# URDF/mesh: https://github.com/fan-ziqi/rl_sar_zoo
src/sim_vln_outdoor/assets/policy/
src/sim_vln_outdoor/assets/rl_sar_zoo/

# PDF / Office documents (papers, proposals)
*.pdf
*.docx
*.xlsx
*.pptx

# Navigation output (visualizations, eval results)
output/

# Logs
*.log
output.log

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

